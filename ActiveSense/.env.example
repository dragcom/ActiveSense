# Public mobile configuration. Use the anon/publishable key, not the service-role or secret key.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
EXPO_PUBLIC_AVATAR_CREATOR_URL=https://activesense.dpdns.org

# Admin-only values are for local migration scripts/CLI and must never be bundled into Expo.
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
